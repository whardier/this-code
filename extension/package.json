{
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "configuration": {
      "properties": {
        "thisCode.enable": {
          "default": true,
          "description": "Enable session recording.",
          "type": "boolean"
        },
        "thisCode.logLevel": {
          "default": "info",
          "description": "Output channel verbosity.",
          "enum": [
            "off",
            "info",
            "debug"
          ],
          "type": "string"
        }
      },
      "title": "This Code"
    }
  },
  "dependencies": {
    "@vscode/sqlite3": "^5.1.12-vscode"
  },
  "description": "Session tracking for VS Code launch context and open file manifests",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.28.0",
    "typescript": "~5.7.0"
  },
  "displayName": "This Code",
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "name": "this-code",
  "publisher": "whardier",
  "repository": "https://github.com/whardier/this-code",
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "package": "vsce package",
    "postpackage": "rm -f LICENSE",
    "prepackage": "cp ../LICENSE LICENSE",
    "pretest": "tsc -p tsconfig.test.json",
    "vscode:prepublish": "node esbuild.js --production",
    "test": "vscode-test",
    "typecheck": "tsc --noEmit",
    "watch": "node esbuild.js --watch"
  },
  "version": "1.1.0"
}
